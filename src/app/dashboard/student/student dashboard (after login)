          scholarId: scholar.id,
          subject: activeQuest.subject,
          answers: results.answers,
          timeSpent: results.timeSpent
        })
      });
      
      // Refresh local state to show updated XP
      fetchScholarData();
    } catch (err) {
      console.error("Failed to sync quest results:", err);
    } finally {
      setActiveQuest(null);
    }
  };

