    process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY
  );

  useEffect(() => {
    fetchScholarData();
  }, []);

  const fetchScholarData = async () => {
    try {
      setLoading(true);
      const scholarId = localStorage.getItem("active_scholar_id");
      
      if (!scholarId) {
        router.push("/auth/student/login");
        return;
      }

      const { data, error } = await supabase
        .from("students")
        .select("*")
        .eq("id", scholarId)
        .single();

      if (error || !data) throw new Error("Scholar not found");
      setScholar(data);
    } catch (err) {
      console.error(err);
      router.push("/auth/student/login");
    } finally {
      setLoading(false);
    }
  };

