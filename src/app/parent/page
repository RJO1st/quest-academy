  <a href={href} {...props} onClick={(e) => e.preventDefault()}>
    {children}
  </a>
);

const createBrowserClient = (url, key) => ({
  auth: {
    getUser: async () => {
      // Mocked user for preview
      return { data: { user: { id: "mock-parent-id", email: "parent@example.com" } }, error: null };
    }
  },
  from: (table) => ({
    select: () => ({
      eq: () => ({
        order: async () => {
          // Mocked scholars for preview
          return { 
            data: [
              { id: "1", name: "Willy", year: 4, region: "GL", total_xp: 1250, proficiency: 75 },
              { id: "2", name: "Sarah", year: 2, region: "GL", total_xp: 850, proficiency: 60 }
            ], 
            error: null 
          };
        }
      })
    }),
    insert: async (data) => {
      console.log("Mocking insert:", data);
      return { error: null };
    }
  })
});

